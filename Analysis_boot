	cluster patid_mtch;
	id _ALL_;
run;
data btspsample_&i.;
set btspsample_&i.;
	if t=0 then newID+1;
run;
proc sort data=btspsample_&i.;
	by trial newID t;
run;

data btspsample_&i._parkin; 
set btspsample_&i.;
	if t>surv_parkin then delete;
run;
data btspsample_&i._parkgp; 
