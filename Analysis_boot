%macro km_step(input=, time=, est=, lower=, upper=, out=);
  proc sort data=&input out=_km_in; by &time; run;

  data &out;
    set _km_in;
    by &time;
    retain prev_time prev_est prev_low prev_up;
    /* keep only complete rows */
    if nmiss(&time, &est, &lower, &upper)=0;
    if _n_=1 then do;
      time     = &time;
      estimate = &est;
      lower    = &lower;
      upper    = &upper;
      output;
      prev_time=time; prev_est=estimate; prev_low=lower; prev_up=upper;
    end;
    else do;
      /* horizontal piece to the new time (repeat previous values at current time) */
      time     = &time;
      estimate = prev_est;
      lower    = prev_low;
      upper    = prev_up;
      output;
      /* vertical jump at the same time (new values) */
      time     = &time;
      estimate = &est;
      lower    = &lower;
      upper    = &upper;
      output;
      prev_time=time; prev_est=estimate; prev_low=lower; prev_up=upper;
    end;
    keep time estimate lower upper;
  run;
  proc datasets nolist; delete _km_in; quit;
%mend;

